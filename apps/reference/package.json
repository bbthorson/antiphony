{
  "name": "@antiphony/reference",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Neutral reference creation app for the Antiphony contract — record → upload → create audio.post → hydrate → render. NO product branding; this is the contract's acceptance harness and the capture-kit seed.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3002",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@antiphony/shared": "*",
    "firebase": "^12.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.16.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.0.0"
  }
}
