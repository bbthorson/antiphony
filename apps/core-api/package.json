{
  "name": "@vox-pop/core-api",
  "version": "0.1.0",
  "private": true,
  "description": "Vox Pop core HTTP service (Hono). Serves the public /api/v1/* surface as a standalone deployment. Phase 4a of the decoupling migration — see specs/decoupling-migration.md.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node esbuild.config.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@vox-pop/core": "*",
    "@vox-pop/shared": "*",
    "firebase-admin": "^13.6.0",
    "hono": "^4.12.22",
    "pino": "^9.5.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.2",
    "globals": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
