{
  "name": "@antiphony/core-api",
  "version": "0.1.0",
  "private": true,
  "description": "Antiphony core HTTP service (Hono). Serves the public /api/v1/* surface as a standalone deployment — see specs/core-surface.md.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node esbuild.config.mjs && npm run gen:openapi",
    "gen:openapi": "tsx scripts/generate-openapi.ts",
    "migrate:processed-blob-cid": "tsx scripts/migrate-processed-blob-cid.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@antiphony/core": "*",
    "@antiphony/shared": "*",
    "@atproto/syntax": "^0.6.4",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-openapi": "^0.19.10",
    "@ipld/dag-cbor": "^10.0.1",
    "ffmpeg-static": "^5.3.0",
    "firebase-admin": "^13.6.0",
    "google-auth-library": "^10.9.0",
    "hono": "^4.12.22",
    "multiformats": "^14.0.3",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "globals": "^15.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
