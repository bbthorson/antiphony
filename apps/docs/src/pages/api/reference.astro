---
/**
 * Standalone API reference page — renders the live OpenAPI spec via
 * Scalar (https://scalar.com). Outside Starlight's content collection
 * so Scalar gets the full viewport (its own sidebar + nav are
 * sufficient; nesting it inside Starlight's chrome cramps the layout).
 *
 * This is a SECONDARY aid. The canonical, hand-written contract is the
 * lexicon reference (src/content/docs/lexicons/overview.md); this page
 * is a generated endpoint lookup, linked from there and from
 * src/content/docs/api/overview.md.
 *
 * The spec is served from `/openapi.json`, copied into `public/` by
 * `scripts/copy-openapi.mjs` at build time.
 */
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>API Reference — Antiphony</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta
            name="description"
            content="Live OpenAPI reference for the Antiphony /api/v1/* surface — posts, audio, actors, identity."
        />
    </head>
    <body>
        <!--
            Scalar's standalone bundle reads its mount config from the
            `<script id="api-reference">` element. `data-url` points at
            the OpenAPI spec; the bundle from jsdelivr handles the rest.
            Both tags need `is:inline` so Astro doesn't try to bundle
            them — the mount-config tag is a marker (not JS to execute)
            and the CDN-hosted bundle is loaded at runtime.
        -->
        <script
            is:inline
            id="api-reference"
            data-url="/openapi.json"
            data-configuration={JSON.stringify({
                theme: 'default',
                layout: 'modern',
                showSidebar: true,
                hideDownloadButton: false,
                metaData: {
                    title: 'Antiphony API',
                },
            })}></script>
        <!--
            Scalar CDN bundle pinned to a specific version. Bumping is a
            deliberate review act — verify the new release renders the
            spec without regressions, then update both the URL and the
            version note in `apps/docs/README.md`.
        -->
        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/@scalar/api-reference@1.57.5"></script>
    </body>
</html>
