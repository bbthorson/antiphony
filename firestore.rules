rules_version = '2';

// Antiphony core-api is the ONLY writer/reader of Firestore — it uses the
// Firebase Admin SDK, which bypasses these rules entirely. No client (the
// reference app included) ever touches Firestore directly; all access is
// mediated by core-api's REST surface. So the rules deny everything: any
// direct client access is a bug, not a feature.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
