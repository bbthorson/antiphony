# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.js

# core-api OpenAPI runner — bundled artifact written + cleaned up by
# `npm run gen:openapi`. Should never persist on disk; ignored as a
# safety net in case the script aborts mid-run.
apps/core-api/.openapi-runner/
apps/core-api/src/__gen-openapi-runner.ts

# testing
coverage/

# build output
build/
dist/
packages/shared/dist/
packages/core/dist/
*.tsbuildinfo

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*
!.env.example
# Committed dev (emulator) + prod (live) config for the reference app. No
# real secrets — demo/localhost in .development; a PUBLIC Firebase web
# apiKey + the live API URL in .production (see each file's header).
!apps/reference/.env.development
!apps/reference/.env.production

# firebase
.firebase
firebase-debug.log*
service-account.json

# log files
*.log

# Claude Code agent worktrees
.claude/worktrees/
